{
  "name": "claude-dj",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite":     "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && NODE_ENV=development electron .",
    "dev":          "concurrently -k -n vite,electron \"npm run dev:vite\" \"npm run dev:electron\"",
    "build":        "tsc -b && vite build",
    "dist":         "npm run build && electron-builder"
  },
  "dependencies": {
    "react":     "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react":            "^19.0.0",
    "@types/react-dom":        "^19.0.0",
    "@vitejs/plugin-react":    "^4.3.4",
    "concurrently":            "^9.1.2",
    "electron":                "^34.0.0",
    "electron-builder":        "^25.1.8",
    "typescript":              "^5.7.2",
    "vite":                    "^6.0.7",
    "wait-on":                 "^8.0.1"
  },
  "build": {
    "appId":       "com.claudedj.app",
    "productName": "Claude DJ",
    "mac": {
      "category": "public.app-category.music",
      "icon":     "public/icon.icns"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../claude-dj",
        "to":   "claude-dj",
        "filter": ["**/*", "!cache/**", "!outputs/**"]
      }
    ]
  }
}
